# E2E Test Environment Configuration

# Required: DAS-capable RPC endpoint
ASSET_ENDPOINT=

# Optional: Surfpool binary path (if not in PATH)
#SURFPOOL_CMD=/opt/homebrew/bin/surfpool

# Required: Path to test wallet keypair (must own test hotspots)
# TEST_WALLET_KEYPAIR_PATH=/path/to/your/test-wallet.json

# Optional: Secondary test wallet for multi-wallet tests
# TEST_WALLET_2_KEYPAIR_PATH=/path/to/your/test-wallet-2.json

# Optional: Onboarding server url
ONBOARDING_ENDPOINT=http://127.0.0.1:3003

# Anchor settings (auto-configured by surfpool helper if not set)
# ANCHOR_WALLET=/path/to/wallet.json
# ANCHOR_PROVIDER_URL=http://127.0.0.1:8899
# Optional: Custom Anchor wallet (defaults to system default)
# ANCHOR_WALLET=/Users/yourname/.config/solana/id.json

# Test environment
NODE_ENV=test
TS_NODE_PROJECT=./tsconfig.test.json